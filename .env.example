# ─── Render Environment Variables ───────────────────────────────────────
# Copy this file to Render's "Environment Variables" section when creating
# a new Web Service. Render makes this very easy.

# 1. Google Identity Services (Client ID for Google Sign-In)
GOOGLE_CLIENT_ID="21454828522-imfo3lhi3hrg4846hpm0m7fbn69t6ds0.apps.googleusercontent.com"

# 2. Database (Optional for testing, required for Production)
# Render provides a free PostgreSQL database. If you don't supply this,
# the app will create a local SQLite `recruitment.db` file (ephemeral on Render).
# DATABASE_URL="postgresql://user:password@host/dbname"
